  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Signup Patient - JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": "{{baseUrl}}/auth/signup/patient",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"patient@example.com\",\n  \"phoneNumber\": \"+1234567890\",\n  \"gender\": \"Male\",\n  \"password\": \"password123\",\n  \"preferredLanguage\": \"en\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Success true\", () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test(\"No password leak\", () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.user).to.not.have.property('password');",
                  "});",
                  "pm.test(\"Has tokens\", () => {",
                  "  const tokens = pm.response.json().data.tokens;",
                  "  pm.expect(tokens).to.have.property('accessToken');",
                  "  pm.expect(tokens).to.have.property('refreshToken');",
                  "});",
                  "pm.environment.set(\"accessToken\", pm.response.json().data.tokens.accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().data.tokens.refreshToken);",
                  "pm.environment.set(\"userId\", pm.response.json().data.user.id);"
                ]
              }
            }
          ]
        },
