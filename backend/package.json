{
  "name": "axon-medical-api",
  "version": "2.0.0",
  "description": "AXON Medical Platform Backend API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "test:report": "npm run test:coverage && npx serve reports",
    "test:ci": "npm run test:coverage -- --ci --reporters=default --reporters=jest-junit"
  },
  "keywords": [
    "medical",
    "healthcare",
    "api",
    "nodejs",
    "express"
  ],
  "author": "AXON Team",
  "license": "ISC",
  "mongodb-memory-server": {
    "download": {
      "downloadDir": "./.cache/mongodb-binaries"
    }
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "email-validator": "^2.0.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^9.0.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "pino": "^8.21.0",
    "pino-multi-stream": "^6.0.0",
    "pino-pretty": "^10.3.1",
    "rate-limiter-flexible": "^4.0.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "xss-clean": "^0.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4"
  }
}
