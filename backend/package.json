{
  "name": "axon-medical-api",
  "version": "1.0.0",
  "description": "AXON Medical Platform Backend API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:file": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --collectCoverageFrom='services/**/*.js' --collectCoverageFrom='controllers/**/*.js' --collectCoverageFrom='middlewares/**/*.js' --collectCoverageFrom='utils/**/*.js' --collectCoverageFrom='models/**/*.js'",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --verbose"
  },
  "keywords": [
    "medical",
    "healthcare",
    "api",
    "nodejs",
    "express"
  ],
  "author": "AXON Team",
  "license": "ISC",
  "mongodb-memory-server": {
    "download": {
      "downloadDir": "./.cache/mongodb-binaries"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "email-validator": "^2.0.4",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.4.0",
    "jest-html-reporters": "^3.1.7",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
