z# Dependencies
# ALWAYS keep package-lock.json in Git for version consistency
node_modules/
/.pnp
.pnp.js

# Build/Dist folders
/dist
/build
/out

# Logs
npm-debug.log
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
# CRITICAL: Keep these private!
.env
.env.local
.env.development
.env.production
.env.test
temp

# TypeScript
*.tsbuildinfo

# Coverage/Test reports
/coverage
.nyc_output

# Editor/OS Files
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
.cache/
reports/
logs/

# Accidental/Temp Files
Notes/
*.zip
routes.md

# Uploaded Content
# We ignore everything inside these folders so test images aren't pushed
Uploads/Certificates/*
Uploads/PersonalPhoto/*
Uploads/Radiology/*
Uploads/LabTests/*

# Optional: Allow the folders themselves to exist in Git without content
!Uploads/**/.gitkeep
